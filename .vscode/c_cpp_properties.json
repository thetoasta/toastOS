{
    "configurations": [
        {
            "name": "toastOS",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "__GNUC__",
                "__asm__(x)=", 
                "__volatile__(x)=",
                "asm(x)=",
                "volatile="
            ],
            "compilerPath": "/usr/bin/x86_64-elf-gcc",
            "cStandard": "gnu11",
            "intelliSenseMode": "linux-gcc-x86",
            "compileCommands": [
                "${workspaceFolder}/toastOS/compile_commands.json"
            ]
        }
    ],
    "version": 4
}